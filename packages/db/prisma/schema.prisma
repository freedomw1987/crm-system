// Prisma schema for CRM System
// Stack: PostgreSQL 16 + Prisma 5.22.0 (pinned, see MEMORY: Prisma 7 breaks SQLite/dev workflow)
//
// Design inspiration: HubSpot + Pipedrive
// Day 1 scope: 11 models for CRM core + AI Agent memory

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. USER & AUTH
// ============================================================

enum UserRole {
  ADMIN       // Full system access
  SALES       // Create/manage quotations, deals, customers
  VIEWER      // Read-only access
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          UserRole  @default(SALES)
  avatarUrl     String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  createdQuotations  Quotation[]   @relation("QuotationCreatedBy")
  ownedDeals         Deal[]        @relation("DealOwner")
  assignedActivities ActivityLog[] @relation("ActivityAssignedTo")
  conversations      Conversation[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ============================================================
// 2. COMPANY (Customer companies)
// ============================================================

model Company {
  id          String   @id @default(cuid())
  name        String
  legalName   String?
  taxId       String?  // 商業登記 / Tax ID
  industry    String?
  website     String?
  phone       String?
  email       String?
  logoUrl     String?
  notes       String?  @db.Text
  // CRM metadata
  source      String?  // e.g., "Website", "Referral", "Cold Call"
  status      String   @default("active") // active / inactive / blacklisted
  // Financial
  creditLimit Decimal? @db.Decimal(12, 2)
  paymentTerms String?  // e.g., "Net 30", "Net 60"
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  contacts     Contact[]
  addresses    Address[]
  tags         CompanyTag[]
  quotations   Quotation[]
  deals        Deal[]
  activities   ActivityLog[]

  @@index([name])
  @@index([status])
  @@map("companies")
}

// ============================================================
// 3. CONTACT (Customer contacts)
// ============================================================

model Contact {
  id          String   @id @default(cuid())
  companyId   String
  firstName   String
  lastName    String
  title       String?  // e.g., "CEO", "Procurement Manager"
  department  String?
  email       String?
  phone       String?
  mobile      String?
  linkedin    String?
  notes       String?  @db.Text
  isPrimary   Boolean  @default(false) // Primary contact for company
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  addresses Address[]
  activities ActivityLog[]

  @@index([companyId])
  @@index([email])
  @@index([lastName, firstName])
  @@map("contacts")
}

// ============================================================
// 4. ADDRESS
// ============================================================

enum AddressType {
  BILLING
  SHIPPING
  OFFICE
  OTHER
}

model Address {
  id          String      @id @default(cuid())
  type        AddressType @default(SHIPPING)
  line1       String
  line2       String?
  city        String
  state       String?
  postalCode  String?
  country     String      @default("HK")
  isDefault   Boolean     @default(false)
  // Polymorphic: can belong to company OR contact
  companyId   String?
  contactId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([contactId])
  @@map("addresses")
}

// ============================================================
// 5. TAG (Flexible tagging system)
// ============================================================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?  // Hex color, e.g., "#3B82F6"
  createdAt DateTime @default(now())

  // Relations
  companies CompanyTag[]

  @@map("tags")
}

model CompanyTag {
  companyId String
  tagId     String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([companyId, tagId])
  @@index([tagId])
  @@map("company_tags")
}

// ============================================================
// 6. PRODUCT (Product catalog)
// ============================================================

enum ProductStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

model Product {
  id            String        @id @default(cuid())
  sku           String        @unique
  name          String
  description   String?       @db.Text
  category      String?
  // Pricing
  unitPrice     Decimal       @db.Decimal(12, 2)
  costPrice     Decimal?      @db.Decimal(12, 2)
  currency      String        @default("HKD")
  // Inventory (optional, can be null for services)
  trackInventory Boolean      @default(false)
  stockQuantity Int?          // null = service / not tracked
  lowStockThreshold Int?      // alert threshold
  // Status
  status        ProductStatus @default(ACTIVE)
  imageUrl      String?
  // Metadata for AI Agent (used in RAG / recommendations)
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  quotationItems QuotationItem[]

  @@index([sku])
  @@index([category])
  @@index([status])
  @@map("products")
}

// ============================================================
// 7. QUOTATION (Quotation header)
// ============================================================

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  INVOICED
}

model Quotation {
  id            String          @id @default(cuid())
  number        String          @unique // e.g., "Q-2026-0001"
  companyId     String
  createdById   String
  // Status
  status        QuotationStatus @default(DRAFT)
  // Dates
  issueDate     DateTime        @default(now())
  validUntil    DateTime?
  sentAt        DateTime?
  viewedAt      DateTime?
  acceptedAt    DateTime?
  // Financial
  subtotal      Decimal         @default(0) @db.Decimal(12, 2)
  taxRate       Decimal         @default(0) @db.Decimal(5, 2) // percentage
  taxAmount     Decimal         @default(0) @db.Decimal(12, 2)
  discount      Decimal         @default(0) @db.Decimal(12, 2)
  total         Decimal         @default(0) @db.Decimal(12, 2)
  currency      String          @default("HKD")
  // Content
  title         String?
  notes         String?         @db.Text
  termsAndConditions String?    @db.Text
  // AI metadata (for agent-generated quotations)
  generatedByAi Boolean         @default(false)
  aiPrompt      String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  company   Company         @relation(fields: [companyId], references: [id])
  createdBy User            @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  items     QuotationItem[]

  @@index([companyId])
  @@index([status])
  @@index([issueDate])
  @@index([createdById])
  @@map("quotations")
}

// ============================================================
// 8. QUOTATION ITEM (Line items)
// ============================================================

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String
  productId   String?
  // Snapshot fields (in case product changes/deletes)
  sku         String?
  name        String
  description String? @db.Text
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2) // percentage
  // Calculated
  lineTotal   Decimal @db.Decimal(12, 2)
  // Ordering
  position    Int     @default(0)

  // Relations
  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quotationId])
  @@index([productId])
  @@map("quotation_items")
}

// ============================================================
// 9. PIPELINE (Sales pipeline configuration)
// ============================================================

model Pipeline {
  id        String   @id @default(cuid())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stages PipelineStage[]
  deals  Deal[]

  @@map("pipelines")
}

model PipelineStage {
  id          String  @id @default(cuid())
  pipelineId  String
  name        String  // e.g., "Lead", "Qualified", "Proposal", "Negotiation", "Won", "Lost"
  position    Int     // Display order
  probability Int     @default(0) // 0-100, win probability %
  color       String?

  // Relations
  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, position])
  @@index([pipelineId])
  @@map("pipeline_stages")
}

// ============================================================
// 10. DEAL (Sales opportunity)
// ============================================================

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id          String     @id @default(cuid())
  title       String
  companyId   String
  ownerId     String     // Sales rep owning the deal
  pipelineId  String
  stageId     String
  // Status
  status      DealStatus @default(OPEN)
  // Financial
  value       Decimal    @db.Decimal(12, 2)
  currency    String     @default("HKD")
  // Dates
  expectedCloseDate DateTime?
  closedAt    DateTime?
  // Content
  description String?    @db.Text
  // Lost reason
  lostReason  String?
  // AI metadata
  aiInsights  Json?      // Cached AI analysis (next best action, risk score, etc.)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  company   Company        @relation(fields: [companyId], references: [id])
  owner     User           @relation("DealOwner", fields: [ownerId], references: [id])
  pipeline  Pipeline       @relation(fields: [pipelineId], references: [id])
  stage     PipelineStage  @relation(fields: [stageId], references: [id])
  activities ActivityLog[]

  @@index([companyId])
  @@index([ownerId])
  @@index([stageId])
  @@index([status])
  @@index([expectedCloseDate])
  @@map("deals")
}

// ============================================================
// 11. ACTIVITY LOG (All customer/deal interactions)
// ============================================================

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
  QUOTATION_SENT
  QUOTATION_VIEWED
  DEAL_STAGE_CHANGED
  SYSTEM
}

model ActivityLog {
  id          String       @id @default(cuid())
  type        ActivityType
  // Polymorphic: can relate to company, contact, or deal
  companyId   String?
  contactId   String?
  dealId      String?
  assignedToId String?     // Sales rep assigned
  // Content
  subject     String?
  body        String?      @db.Text
  // Metadata
  metadata    Json?        // e.g., {duration: 1800, outcome: "interested"}
  // Timing
  dueAt       DateTime?    // For tasks
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  // Relations
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal       Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("ActivityAssignedTo", fields: [assignedToId], references: [id])

  @@index([companyId])
  @@index([contactId])
  @@index([dealId])
  @@index([type])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================================
// 12. CONVERSATION (AI Agent memory)
// ============================================================

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String?   // Auto-generated from first message
  // Context (what data the agent had access to during this conversation)
  context   Json?     // Snapshot of relevant CRM data (companies, deals, etc.)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("conversations")
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant" | "tool"
  content        String   @db.Text
  // For tool calls
  toolName       String?
  toolArgs       Json?
  toolResult     Json?
  // Token tracking (for cost monitoring)
  promptTokens   Int?
  completionTokens Int?
  createdAt      DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}
