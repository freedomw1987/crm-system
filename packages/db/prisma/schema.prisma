// Prisma schema for CRM System
// Stack: PostgreSQL 16 + Prisma 5.22.0 (pinned, see MEMORY: Prisma 7 breaks SQLite/dev workflow)
//
// Design inspiration: HubSpot + Pipedrive
// Day 1 scope: 11 models for CRM core + AI Agent memory

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. USER & AUTH
// ============================================================

// NOTE: UserRole enum kept for backwards compat + new Role table replaces it
// in Day 7. The enum is no longer the source of truth — see Role model below.
enum UserRole {
  ADMIN
  SALES
  VIEWER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  // Day 7: role moved to FK (Role table holds the actual permission set)
  // We keep the enum column for now to ease the migration; new code reads roleId
  // and the legacy column is set as a denormalized hint only.
  role         UserRole  @default(SALES)
  roleId       String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  roleRef             Role?          @relation(fields: [roleId], references: [id], onDelete: SetNull)
  createdQuotations   Quotation[]    @relation("QuotationCreatedBy")
  // 2026-06-26: a User can be the follow-up salesperson on multiple
  // quotations (separate from whoever created the row). Nullable so
  // deleting a User doesn't cascade to break the quotation link;
  // the UI falls back to `createdById` when `salesRepId` is null.
  salesRepQuotations  Quotation[]    @relation("QuotationSalesRep")
  ownedDeals          Deal[]         @relation("DealOwner")
  // New Activity system (replaces ActivityLog):
  //   authoredActivities = activities I created (sales rep logs note/call/meeting)
  //   assignedActivities = activities assigned to me (rare in v1, kept for future)
  authoredActivities  Activity[]     @relation("ActivityAuthor")
  assignedActivities  Activity[]     @relation("ActivityAssignedTo")
  uploadedAttachments Attachment[]   @relation("AttachmentUploader")
  conversations       Conversation[]
  auditEvents         AuditLog[]     @relation("AuditActor")
  aiConfigUpdates     AiConfig[]     @relation("AiConfigUpdater")
  systemConfigUpdates SystemConfig[] @relation("SystemConfigUpdater")

  @@index([email])
  @@index([role])
  @@index([roleId])
  @@map("users")
}

// ============================================================
// 1b. ROLE & RBAC (Day 7: dynamic role management)
// ============================================================
// System roles (ADMIN/SALES/VIEWER) are seeded from packages/shared/src/permissions.ts.
// isSystem=true means the role cannot be deleted and its name is locked.
// Custom roles can be created freely with any subset of permissions.

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // "ADMIN", "SALES", "Senior Sales" (custom)
  displayName String // "Administrator", "Sales Rep", ...
  description String?
  isSystem    Boolean  @default(false) // system roles cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model RolePermission {
  roleId     String
  permission String // string from Permission enum in @crm/shared/permissions
  createdAt  DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
  @@index([permission])
  @@map("role_permissions")
}

// ============================================================
// 2. COMPANY (Customer companies)
// ============================================================

// Day 9: Region table replaces the previous Region enum. Why a table?
//   1. Admins need to add new regions (Taiwan, Singapore, Japan) without
//      a DDL migration every time
//   2. The Region list is now surfaceable via /api/regions so the UI can
//      render filter pills and a "free-form" customRegion option from a
//      single source of truth
// `customRegion` on Company is preserved as a free-form text field for the
// case where the desired region isn't (yet) in the catalogue.
model Region {
  id        String   @id @default(cuid())
  code      String   @unique // "HK", "MO", "CN", "OTHER", or any new code
  name      String // "Hong Kong", "中國 China", etc.
  flag      String? // emoji or short label, optional
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies Company[]

  @@map("regions")
}

model Company {
  id           String  @id @default(cuid())
  name         String
  legalName    String?
  taxId        String? // 商業登記 / Tax ID
  industry     String?
  website      String?
  phone        String?
  email        String?
  logoUrl      String?
  notes        String? @db.Text
  // CRM metadata
  source       String? // e.g., "Website", "Referral", "Cold Call"
  status       String  @default("active") // active / inactive / blacklisted
  // Region (Day 9) — foreign key to the Region table for known regions
  // (HK/MO/CN/OTHER and any future additions). `customRegion` remains as a
  // free-form label that overrides the FK lookup when filled in.
  regionId     String?
  region       Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)
  customRegion String? // populated only when region FK is set to OTHER (or null)

  // Financial
  creditLimit  Decimal? @db.Decimal(12, 2)
  paymentTerms String? // e.g., "Net 30", "Net 60"
  // Timestamps
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  contacts   Contact[]
  addresses  Address[]
  tags       CompanyTag[]
  quotations Quotation[]
  deals      Deal[]
  activities Activity[]

  @@index([name])
  @@index([status])
  @@map("companies")
}

// ============================================================
// 3. CONTACT (Customer contacts)
// ============================================================

model Contact {
  id         String   @id @default(cuid())
  companyId  String
  firstName  String
  lastName   String
  title      String? // e.g., "CEO", "Procurement Manager"
  department String?
  email      String?
  phone      String?
  mobile     String?
  linkedin   String?
  notes      String?  @db.Text
  isPrimary  Boolean  @default(false) // Primary contact for company
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  addresses Address[]
  // (No direct Activity relation — activities are attached at the Company
  // or Deal level only. Contact-level activities are not in v1 scope.)

  @@index([companyId])
  @@index([email])
  @@index([lastName, firstName])
  @@map("contacts")
}

// ============================================================
// 4. ADDRESS
// ============================================================

enum AddressType {
  BILLING
  SHIPPING
  OFFICE
  OTHER
}

model Address {
  id         String      @id @default(cuid())
  type       AddressType @default(SHIPPING)
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String?
  country    String      @default("HK")
  isDefault  Boolean     @default(false)
  // Polymorphic: can belong to company OR contact
  companyId  String?
  contactId  String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  // Relations
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([contactId])
  @@map("addresses")
}

// ============================================================
// 5. TAG (Flexible tagging system)
// ============================================================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String? // Hex color, e.g., "#3B82F6"
  createdAt DateTime @default(now())

  // Relations
  companies CompanyTag[]

  @@map("tags")
}

model CompanyTag {
  companyId String
  tagId     String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([companyId, tagId])
  @@index([tagId])
  @@map("company_tags")
}

// ============================================================
// 6. PRODUCT (Product catalog)
// ============================================================

enum ProductStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

model Product {
  id                String        @id @default(cuid())
  sku               String        @unique
  name              String
  description       String?       @db.Text
  category          String?
  // Pricing
  unitPrice         Decimal       @db.Decimal(12, 2)
  costPrice         Decimal?      @db.Decimal(12, 2)
  currency          String        @default("RMB")
  // Inventory (optional, can be null for services)
  trackInventory    Boolean       @default(false)
  stockQuantity     Int? // null = service / not tracked
  lowStockThreshold Int? // alert threshold
  // Status
  status            ProductStatus @default(ACTIVE)
  imageUrl          String?
  // Metadata for AI Agent (used in RAG / recommendations)
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  quotationItems QuotationItem[]

  @@index([sku])
  @@index([category])
  @@index([status])
  @@map("products")
}

// ============================================================
// 6b. SERVICE (Service catalog with man-day breakdown)
// ============================================================
// Day 7: Services are first-class catalogue items distinct from Products.
// A service has a fixed unit price and an immutable man-day breakdown that
// documents how the price is composed (for SOW purposes). When a service is
// added to a quotation, its name/SOW/unitPrice are snapshotted into the
// QuotationItem — the original service can be edited without breaking past
// quotations.

enum ServiceStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

model Service {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text // SOW (Statement of Work) — long form
  category    String? // e.g., "Consulting", "Implementation", "Training"
  // Pricing — locked-in total for the service; not derived from manDayLines
  unitPrice   Decimal       @db.Decimal(12, 2)
  currency    String        @default("RMB")
  // Status
  status      ServiceStatus @default(ACTIVE)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  manDayLines    ServiceManDay[]
  quotationItems QuotationItem[]

  @@index([status])
  @@index([category])
  @@map("services")
}

model ServiceManDay {
  id           String   @id @default(cuid())
  serviceId    String
  // Day N: man-day role is now selected from the admin-managed ManDayRole
  // catalogue. The `role` text field is kept as a denormalized display name
  // snapshot so renaming a ManDayRole doesn't break existing services.
  // dayRate is also denormalized at the time the line was added so the
  // service's pricing can be reviewed even if the ManDayRole's price later
  // changes (DRAFT services still pick up the new rate on rebuild).
  manDayRoleId String? // nullable for legacy rows
  role         String // snapshot of ManDayRole.name at line create time
  dayRate      Decimal  @db.Decimal(12, 2) // sell price per man-day (snapshot)
  costRate     Decimal  @default(0) @db.Decimal(12, 2) // cost per man-day (snapshot)
  days         Decimal  @db.Decimal(6, 2)
  // subtotal = dayRate * days (sell side). Cost side is recomputed when
  // needed; we don't store it because Service-level GP is a derived view.
  subtotal     Decimal  @db.Decimal(12, 2)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  manDayRole ManDayRole? @relation(fields: [manDayRoleId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([manDayRoleId])
  @@map("service_man_days")
}

// ============================================================
// 6c. MAN-DAY ROLE (Day N — admin-managed role catalogue)
// ============================================================
// Admins define roles (e.g. "Senior Engineer", "Project Manager") and
// each role has a sell price + cost per man-day. Services reference
// roles through ServiceManDay. DRAFT services pick up the latest price
// on re-render; DRAFT quotations already-snapshotted values stay frozen.
//
// Currency is locked to CNY (per David Day N). If we need multi-currency
// later, add `currency String @default("CNY")` to this table — breaking
// because QuotationItem snapshots still need to migrate.

model ManDayRole {
  id        String   @id @default(cuid())
  name      String   @unique // "Senior Engineer"
  price     Decimal  @db.Decimal(12, 2) // sell per man-day
  cost      Decimal  @default(0) @db.Decimal(12, 2) // cost per man-day
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceLines ServiceManDay[]

  @@index([isActive, sortOrder])
  @@map("man_day_roles")
}

// ============================================================
// 7. QUOTATION (Quotation header)
// ============================================================

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  INVOICED
}

model Quotation {
  id                 String          @id @default(cuid())
  number             String          @unique // e.g., "Q-2026-0001"
  companyId          String
  createdById        String
  // Day 8: link to a Deal (sales pipeline opportunity). Optional — a quote can exist
  // standalone, but typically every quote is part of a deal. Reverse relation on Deal
  // lets the Deal show all its quotations (revisions, alternatives).
  dealId             String?
  // Status
  status             QuotationStatus @default(DRAFT)
  // Dates
  issueDate          DateTime        @default(now())
  validUntil         DateTime?
  sentAt             DateTime?
  viewedAt           DateTime?
  acceptedAt         DateTime?
  // Financial
  subtotal           Decimal         @default(0) @db.Decimal(12, 2)
  taxRate            Decimal         @default(0) @db.Decimal(5, 2) // percentage
  taxAmount          Decimal         @default(0) @db.Decimal(12, 2)
  discount           Decimal         @default(0) @db.Decimal(12, 2)
  total              Decimal         @default(0) @db.Decimal(12, 2)
  // Billing currency chosen by the sales rep at create/edit time.
  // Default = RMB (the system default; admin can change in
  // /settings/currency). The two snapshot fields below capture the
  // HKD equivalent at save time so historical reports stay stable
  // when the admin later changes the exchange rates.
  //   exchangeRateToHKD — the rate that was applied (1 RMB = X HKD,
  //                      or derived for non-RMB currencies)
  //   totalHKD          — pre-computed HKD total at save time
  //                      (read path uses this directly; do not
  //                      recompute on the fly, or rate changes
  //                      would silently rewrite history)
  currency           String          @default("RMB")
  exchangeRateToHKD  Decimal         @default(1) @db.Decimal(10, 6)
  totalHKD           Decimal         @default(0) @db.Decimal(12, 2)
  // Content
  title              String?
  notes              String?         @db.Text
  termsAndConditions String?         @db.Text
  // AI metadata (for agent-generated quotations)
  generatedByAi      Boolean         @default(false)
  aiPrompt           String?         @db.Text
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // Relations
  company   Company         @relation(fields: [companyId], references: [id])
  createdBy User            @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  // 2026-06-26: optional follow-up salesperson. Separate from
  // `createdById` because the creator (e.g. a sales engineer
  // building the quote) is often not the same person who follows
  // up with the customer (e.g. an account exec). Nullable so
  // (a) the migration backfill can copy `created_by_id` per row,
  // and (b) deleting a User doesn't cascade-block the quotation.
  // The API defaults salesRepId to the authenticated user on
  // create when omitted, so newly-created rows always have a
  // sales rep unless explicitly cleared.
  salesRepId String?
  salesRep   User?           @relation("QuotationSalesRep", fields: [salesRepId], references: [id], onDelete: SetNull)
  deal      Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  items     QuotationItem[]
  // 2026-06-26: revision chain. parentQuotationId points to the
  // immediate predecessor (null for the original). revisionNumber
  // is 0 for an original, 1 for R1, 2 for R2, etc. The full chain
  // is recoverable via parentQuotationId links; the revisionNumber
  // is just a position counter so the UI can render "R2 of 4"
  // without walking the chain every time. ON DELETE SET NULL on
  // parent so deleting a row in the middle of a chain doesn't
  // orphan the descendants (they become new roots themselves).
  parentQuotationId String?
  parentQuotation   Quotation?  @relation("QuotationRevisions", fields: [parentQuotationId], references: [id], onDelete: SetNull)
  revisions         Quotation[] @relation("QuotationRevisions")
  revisionNumber    Int         @default(0)

  @@index([companyId])
  @@index([status])
  @@index([issueDate])
  @@index([createdById])
  @@index([salesRepId])
  @@index([dealId])
  @@index([parentQuotationId])
  @@map("quotations")
}

// ============================================================
// 8. QUOTATION ITEM (Line items — polymorphic Product or Service)
// ============================================================
// Day 7: a line item is either a Product or a Service. Whichever it is, the
// name/description/unitPrice are snapshotted at quotation time so the
// historical quote doesn't drift when the catalogue changes.

// ItemType is stored as a plain String in the database (column type: text)
// rather than as a Postgres enum. The two valid values are:
//   "PRODUCT" — a physical or downloadable good; productId is set
//   "SERVICE" — a labour-based deliverable; serviceId is set
// We chose text because:
//   1. adding new item types (e.g. SUBSCRIPTION, USAGE) shouldn't require
//      a DDL migration — just a new string value
//   2. the schema/DB were created without the enum originally, and
//      backfilling an enum now would require a one-shot migration that's
//      not worth the cost given how rarely this column changes
// Day 8: code MUST always use one of the two values above.

model QuotationItem {
  id             String  @id @default(cuid())
  quotationId    String
  // Polymorphic: exactly one of productId or serviceId is set
  itemType       String  @default("PRODUCT")
  productId      String?
  serviceId      String?
  // Snapshot fields (immutable after creation)
  sku            String? // for products; null for services
  name           String
  description    String? @db.Text
  // SOW/breakdown snapshot for service items: { lines: [{role, dayRate, days, subtotal}], notes }
  // For product items this stays null.
  manDaySnapshot Json?
  // Pricing
  quantity       Decimal @db.Decimal(10, 2)
  unitPrice      Decimal @db.Decimal(12, 2) // service.unitPrice or product.unitPrice at snapshot
  discount       Decimal @default(0) @db.Decimal(5, 2) // percentage
  lineTotal      Decimal @db.Decimal(12, 2) // = quantity * unitPrice * (1 - discount/100)
  // Day N: GP snapshot fields. Recomputed on every update while the
  // quotation is DRAFT (server-side); frozen on SENT. PRODUCT lines
  // have costSnapshot=0 (GP% = 100%). SERVICE lines have costSnapshot =
  // sum(manDayLine.costRate * days). lineGp = lineTotal - (costSnapshot *
  // quantity for service, 0 for product). lineGpPercent = lineGp/lineTotal
  // (or 100 if product).
  costSnapshot   Decimal @default(0) @db.Decimal(12, 2)
  lineGp         Decimal @default(0) @db.Decimal(12, 2)
  lineGpPercent  Decimal @default(100) @db.Decimal(5, 2)
  position       Int     @default(0)

  // Relations
  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  service   Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([quotationId])
  @@index([productId])
  @@index([serviceId])
  @@index([itemType])
  @@map("quotation_items")
}

// ============================================================
// 9. PIPELINE (Sales pipeline configuration)
// ============================================================

model Pipeline {
  id        String   @id @default(cuid())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stages PipelineStage[]
  deals  Deal[]

  @@map("pipelines")
}

model PipelineStage {
  id          String  @id @default(cuid())
  pipelineId  String
  name        String // e.g., "Lead", "Qualified", "Proposal", "Negotiation", "Won", "Lost"
  position    Int // Display order
  probability Int     @default(0) // 0-100, win probability %
  color       String?

  // Relations
  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, position])
  @@index([pipelineId])
  @@map("pipeline_stages")
}

// ============================================================
// 10. DEAL (Sales opportunity)
// ============================================================

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  companyId         String
  ownerId           String // Sales rep owning the deal
  pipelineId        String
  stageId           String
  // Status
  status            DealStatus @default(OPEN)
  // Financial
  value             Decimal    @db.Decimal(12, 2)
  currency          String     @default("RMB")
  // Dates
  expectedCloseDate DateTime?
  closedAt          DateTime?
  // Content
  description       String?    @db.Text
  // Lost reason
  lostReason        String?
  // AI metadata
  aiInsights        Json? // Cached AI analysis (next best action, risk score, etc.)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  company    Company       @relation(fields: [companyId], references: [id])
  owner      User          @relation("DealOwner", fields: [ownerId], references: [id])
  pipeline   Pipeline      @relation(fields: [pipelineId], references: [id])
  stage      PipelineStage @relation(fields: [stageId], references: [id])
  quotations Quotation[] // Day 8: a deal can have multiple quotations (revisions)
  activities Activity[]

  @@index([companyId])
  @@index([ownerId])
  @@index([stageId])
  @@index([status])
  @@index([expectedCloseDate])
  @@map("deals")
}

// ============================================================
// 11. ACTIVITY (Customer/deal interactions — David Day N feature)
// ============================================================
// Polymorphic: an activity belongs to EITHER a company OR a deal
// (exactly one of companyId / dealId is set). Every activity is written
// by an author (sales rep / admin) and may carry attachments.
//
// Day N design choices:
//   1. NOT a soft task scheduler: no dueAt/completedAt. If we need that
//      later we add a "Task" subtype. For v1 the type enum is just for
//      icon & color in the feed.
//   2. authorId REQUIRED. assignedToId is optional and currently unused;
//      kept so we can later route "follow up" reminders without another
//      migration.
//   3. NO backfill from ActivityLog: that table is dropped (see below)
//      because it was never wired into any route (zero code references).
//
// On GP: activities don't compute GP. They're free-form context.

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
}

model Activity {
  id           String       @id @default(cuid())
  // Polymorphic owner — exactly one of companyId / dealId is set.
  // We don't enforce "exactly one" at the DB level (would need a CHECK
  // constraint with OR); the API layer validates and we keep the schema
  // simple.
  companyId    String?
  dealId       String?
  // Author & assignment
  authorId     String
  assignedToId String?
  // Content
  type         ActivityType @default(NOTE)
  content      String       @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  author      User         @relation("ActivityAuthor", fields: [authorId], references: [id])
  assignedTo  User?        @relation("ActivityAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  attachments Attachment[]

  @@index([companyId, createdAt(sort: Desc)])
  @@index([dealId, createdAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@index([type])
  @@map("activities")
}

model Attachment {
  id           String   @id @default(cuid())
  // Required owner: every attachment belongs to an activity.
  // (We considered a polymorphic "could attach to anything" model, but
  // for v1 keeping attachments scoped to activities matches the UI:
  // CompanyDetail -> Attachment tab lists attachments by traversing
  // company.activities[].attachments. Simpler joins, simpler queries.)
  activityId   String
  // File metadata
  fileName     String
  mimeType     String
  sizeBytes    Int
  // Storage key is the on-disk relative path under DATA_DIR (default
  // /app/data/uploads). Not the absolute path — keeps container hosts
  // swappable. The Download route joins DATA_DIR + storageKey.
  storageKey   String   @unique
  uploadedById String
  createdAt    DateTime @default(now())

  // Relations
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("AttachmentUploader", fields: [uploadedById], references: [id])

  @@index([activityId])
  @@index([uploadedById])
  @@map("attachments")
}

// ============================================================
// 12. CONVERSATION (AI Agent memory)
// ============================================================

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String? // Auto-generated from first message
  // Context (what data the agent had access to during this conversation)
  context   Json? // Snapshot of relevant CRM data (companies, deals, etc.)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("conversations")
}

model ConversationMessage {
  id               String   @id @default(cuid())
  conversationId   String
  role             String // "user" | "assistant" | "tool"
  content          String   @db.Text
  // For tool calls
  toolName         String?
  toolArgs         Json?
  toolResult       Json?
  // Day 17 (US-C5): SHA-256(first 8 bytes) of the proposed args for
  // confirmation-required tool calls. Lets us correlate the persisted
  // row with the matching AI_TOOL_CONFIRMED / AI_TOOL_DENIED audit
  // log entry without storing PII in the audit log itself.
  aiToolConfirmationHash String?
  // Token tracking (for cost monitoring)
  promptTokens     Int?
  completionTokens Int?
  createdAt        DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

// ============================================================
// 13. AUDIT LOG (Admin-visible system event trail)
// ============================================================

enum AuditAction {
  // Auth
  USER_LOGIN
  USER_LOGIN_FAILED
  USER_LOGOUT
  PASSWORD_CHANGED
  // User management
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  USER_REACTIVATED
  USER_DELETED
  PASSWORD_RESET
  // Role management (Day 7)
  ROLE_CREATED
  ROLE_UPDATED
  ROLE_DELETED
  // CRM resources
  QUOTATION_CREATED
  QUOTATION_UPDATED
  QUOTATION_DELETED
  QUOTATION_STATUS_CHANGED
  COMPANY_CREATED
  COMPANY_UPDATED
  COMPANY_DELETED
  CONTACT_CREATED
  CONTACT_UPDATED
  CONTACT_DELETED
  DEAL_CREATED
  DEAL_UPDATED
  DEAL_DELETED
  // P1-1 (2026-06-08): deal stage transitions need their own action
  // for the stage-history diff in the audit log UI.
  DEAL_STAGE_CHANGED
  // P1-1 (2026-06-08): region CRUD was using strings not in the
  // enum, so TS errored at the call sites. Add proper enum values.
  REGION_CREATED
  REGION_UPDATED
  REGION_DELETED
  // P1-1 (2026-06-08): settings CRUD was using 'CREATE' / 'UPDATE'
  // / 'DELETE' as raw strings (overloaded across multiple resource
  // types). Add proper enum values; future code should prefer
  // resource-specific actions.
  CREATE
  UPDATE
  DELETE
  // Service catalogue (Day 7)
  SERVICE_CREATED
  SERVICE_UPDATED
  SERVICE_DELETED
  // Product catalogue
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  // Man-day role catalogue (Day N)
  MAN_DAY_ROLE_CREATED
  MAN_DAY_ROLE_UPDATED
  MAN_DAY_ROLE_DELETED
  // Activity / Attachment (Day N)
  ACTIVITY_CREATED
  ACTIVITY_DELETED
  ATTACHMENT_UPLOADED
  ATTACHMENT_DELETED
  // AI Configuration (Day 10+)
  AI_CONFIG_UPDATED
  // AI tool confirmation guardrail (Day 17, US-C5)
  AI_TOOL_CONFIRMED
  AI_TOOL_DENIED
  // System Configuration (Day 14+)
  SYSTEM_CONFIG_UPDATED
}

model AuditLog {
  id           String      @id @default(cuid())
  // Actor
  actorId      String? // null = anonymous / system
  // What happened
  action       AuditAction
  // Affected resource
  resourceType String? // e.g., "quotation", "user", "company"
  resourceId   String?
  // Free-form context
  description  String?     @db.Text
  metadata     Json? // before/after diff, etc.
  // Request context
  ipAddress    String?
  userAgent    String?     @db.Text
  createdAt    DateTime    @default(now())

  // Relations
  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// 14. AI CONFIGURATION (Day 10+)
// ============================================================
//
// Singleton row (id=1) storing the AI Assistant's connection to the
// external LLM provider. The apiKey is stored encrypted at rest using
// AES-256-GCM keyed off the server-side `AI_CONFIG_ENCRYPTION_KEY` env
// var (master key). Endpoint URL, model name, and system prompt are
// stored in plaintext because they aren't secret.
//
// Admin can edit via /admin/ai-config (no other surface). The chat route
// loads this row on every request to drive the OpenAI client — no env-var
// fallback, by design (David's T2 spec: "no LLM env defaults").

model AiConfig {
  id            Int      @id @default(1) // Singleton: always 1
  // LLM provider connection
  endpointUrl   String   // e.g. https://api.openai.com/v1
  apiKeyCipher  String   @db.Text // AES-256-GCM: base64(iv || ciphertext || tag)
  modelName     String   // e.g. gpt-4o, claude-3-5-sonnet, custom model
  // Optional system prompt override (defaults to packages/ai/src/prompts.ts)
  systemPrompt  String?  @db.Text
  // Audit
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  updatedById   String?

  updatedBy User? @relation("AiConfigUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("ai_config")
}

// ============================================================
// 15. SYSTEM CONFIGURATION (Day 14+)
// ============================================================
//
// Generic key-value store for admin-managed system defaults that
// need to be read at runtime by the application layer (e.g. default
// tax rate, default currency, default pipeline, etc.). Each row is
// addressed by a stable `key` string; `value` holds the typed JSON
// payload (Decimal numbers, strings, nested objects).
//
// Why a table (not env vars)?
//   1. Admins can change values from the UI without a deploy.
//   2. Changes are auditable (SYSTEM_CONFIG_UPDATED) and reversible.
//   3. Multi-instance deploys share one source of truth.
//
// Retention: changes are not soft-deleted (we keep the latest value
// only); full history lives in the audit_logs table (metadata holds
// the before/after diff per ADR-0014 12-month retention).

model SystemConfig {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("SystemConfigUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("system_config")
}
