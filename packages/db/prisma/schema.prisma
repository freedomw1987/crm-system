// Prisma schema for CRM System
// Stack: PostgreSQL 16 + Prisma 5.22.0 (pinned, see MEMORY: Prisma 7 breaks SQLite/dev workflow)
//
// Design inspiration: HubSpot + Pipedrive
// Day 1 scope: 11 models for CRM core + AI Agent memory

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. USER & AUTH
// ============================================================

// NOTE: UserRole enum kept for backwards compat + new Role table replaces it
// in Day 7. The enum is no longer the source of truth — see Role model below.
enum UserRole {
  ADMIN
  SALES
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  // Day 7: role moved to FK (Role table holds the actual permission set)
  // We keep the enum column for now to ease the migration; new code reads roleId
  // and the legacy column is set as a denormalized hint only.
  role          UserRole  @default(SALES)
  roleId        String?
  avatarUrl     String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  roleRef          Role?              @relation(fields: [roleId], references: [id], onDelete: SetNull)
  createdQuotations  Quotation[]      @relation("QuotationCreatedBy")
  ownedDeals         Deal[]           @relation("DealOwner")
  assignedActivities ActivityLog[]    @relation("ActivityAssignedTo")
  conversations      Conversation[]
  auditEvents        AuditLog[]       @relation("AuditActor")

  @@index([email])
  @@index([role])
  @@index([roleId])
  @@map("users")
}

// ============================================================
// 1b. ROLE & RBAC (Day 7: dynamic role management)
// ============================================================
// System roles (ADMIN/SALES/VIEWER) are seeded from packages/shared/src/permissions.ts.
// isSystem=true means the role cannot be deleted and its name is locked.
// Custom roles can be created freely with any subset of permissions.

model Role {
  id          String   @id @default(cuid())
  name        String   @unique         // "ADMIN", "SALES", "Senior Sales" (custom)
  displayName String                    // "Administrator", "Sales Rep", ...
  description String?
  isSystem    Boolean  @default(false) // system roles cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model RolePermission {
  roleId     String
  permission String   // string from Permission enum in @crm/shared/permissions
  createdAt  DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
  @@index([permission])
  @@map("role_permissions")
}

// ============================================================
// 2. COMPANY (Customer companies)
// ============================================================

// Day 8: regional segmentation for HK/MO/CN primary markets + free-form for "other"
// Region enum ensures data integrity for the 3 primary regions; customRegion captures
// free-form labels (e.g., "Taiwan", "Singapore") chosen when region = OTHER.
enum Region {
  HK
  MO
  CN
  OTHER
}

model Company {
  id          String   @id @default(cuid())
  name        String
  legalName   String?
  taxId       String?  // 商業登記 / Tax ID
  industry    String?
  website     String?
  phone       String?
  email       String?
  logoUrl     String?
  notes       String?  @db.Text
  // CRM metadata
  source      String?  // e.g., "Website", "Referral", "Cold Call"
  status      String   @default("active") // active / inactive / blacklisted
  // Region (Day 8) — primary 3 are enum-locked; OTHER falls through to customRegion
  region      Region   @default(HK)
  customRegion String?  // populated only when region = OTHER
  // Financial
  creditLimit Decimal? @db.Decimal(12, 2)
  paymentTerms String?  // e.g., "Net 30", "Net 60"
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  contacts     Contact[]
  addresses    Address[]
  tags         CompanyTag[]
  quotations   Quotation[]
  deals        Deal[]
  activities   ActivityLog[]

  @@index([name])
  @@index([status])
  @@map("companies")
}

// ============================================================
// 3. CONTACT (Customer contacts)
// ============================================================

model Contact {
  id          String   @id @default(cuid())
  companyId   String
  firstName   String
  lastName    String
  title       String?  // e.g., "CEO", "Procurement Manager"
  department  String?
  email       String?
  phone       String?
  mobile      String?
  linkedin    String?
  notes       String?  @db.Text
  isPrimary   Boolean  @default(false) // Primary contact for company
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  addresses Address[]
  activities ActivityLog[]

  @@index([companyId])
  @@index([email])
  @@index([lastName, firstName])
  @@map("contacts")
}

// ============================================================
// 4. ADDRESS
// ============================================================

enum AddressType {
  BILLING
  SHIPPING
  OFFICE
  OTHER
}

model Address {
  id          String      @id @default(cuid())
  type        AddressType @default(SHIPPING)
  line1       String
  line2       String?
  city        String
  state       String?
  postalCode  String?
  country     String      @default("HK")
  isDefault   Boolean     @default(false)
  // Polymorphic: can belong to company OR contact
  companyId   String?
  contactId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([contactId])
  @@map("addresses")
}

// ============================================================
// 5. TAG (Flexible tagging system)
// ============================================================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?  // Hex color, e.g., "#3B82F6"
  createdAt DateTime @default(now())

  // Relations
  companies CompanyTag[]

  @@map("tags")
}

model CompanyTag {
  companyId String
  tagId     String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([companyId, tagId])
  @@index([tagId])
  @@map("company_tags")
}

// ============================================================
// 6. PRODUCT (Product catalog)
// ============================================================

enum ProductStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

model Product {
  id            String        @id @default(cuid())
  sku           String        @unique
  name          String
  description   String?       @db.Text
  category      String?
  // Pricing
  unitPrice     Decimal       @db.Decimal(12, 2)
  costPrice     Decimal?      @db.Decimal(12, 2)
  currency      String        @default("HKD")
  // Inventory (optional, can be null for services)
  trackInventory Boolean      @default(false)
  stockQuantity Int?          // null = service / not tracked
  lowStockThreshold Int?      // alert threshold
  // Status
  status        ProductStatus @default(ACTIVE)
  imageUrl      String?
  // Metadata for AI Agent (used in RAG / recommendations)
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  quotationItems QuotationItem[]

  @@index([sku])
  @@index([category])
  @@index([status])
  @@map("products")
}

// ============================================================
// 6b. SERVICE (Service catalog with man-day breakdown)
// ============================================================
// Day 7: Services are first-class catalogue items distinct from Products.
// A service has a fixed unit price and an immutable man-day breakdown that
// documents how the price is composed (for SOW purposes). When a service is
// added to a quotation, its name/SOW/unitPrice are snapshotted into the
// QuotationItem — the original service can be edited without breaking past
// quotations.

enum ServiceStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

model Service {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text  // SOW (Statement of Work) — long form
  category    String?                  // e.g., "Consulting", "Implementation", "Training"
  // Pricing — locked-in total for the service; not derived from manDayLines
  unitPrice   Decimal       @db.Decimal(12, 2)
  currency    String        @default("HKD")
  // Status
  status      ServiceStatus @default(ACTIVE)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  manDayLines ServiceManDay[]
  quotationItems QuotationItem[]

  @@index([status])
  @@index([category])
  @@map("services")
}

model ServiceManDay {
  id        String   @id @default(cuid())
  serviceId String
  role      String   // e.g., "Senior Consultant", "Junior Engineer" (free-form for now)
  dayRate   Decimal  @db.Decimal(12, 2)
  days      Decimal  @db.Decimal(6, 2)
  // snapshot of line subtotal = dayRate * days, computed at write time
  subtotal  Decimal  @db.Decimal(12, 2)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_man_days")
}

// ============================================================
// 7. QUOTATION (Quotation header)
// ============================================================

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  INVOICED
}

model Quotation {
  id            String          @id @default(cuid())
  number        String          @unique // e.g., "Q-2026-0001"
  companyId     String
  createdById   String
  // Day 8: link to a Deal (sales pipeline opportunity). Optional — a quote can exist
  // standalone, but typically every quote is part of a deal. Reverse relation on Deal
  // lets the Deal show all its quotations (revisions, alternatives).
  dealId        String?
  // Status
  status        QuotationStatus @default(DRAFT)
  // Dates
  issueDate     DateTime        @default(now())
  validUntil    DateTime?
  sentAt        DateTime?
  viewedAt      DateTime?
  acceptedAt    DateTime?
  // Financial
  subtotal      Decimal         @default(0) @db.Decimal(12, 2)
  taxRate       Decimal         @default(0) @db.Decimal(5, 2) // percentage
  taxAmount     Decimal         @default(0) @db.Decimal(12, 2)
  discount      Decimal         @default(0) @db.Decimal(12, 2)
  total         Decimal         @default(0) @db.Decimal(12, 2)
  currency      String          @default("HKD")
  // Content
  title         String?
  notes         String?         @db.Text
  termsAndConditions String?    @db.Text
  // AI metadata (for agent-generated quotations)
  generatedByAi Boolean         @default(false)
  aiPrompt      String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  company   Company         @relation(fields: [companyId], references: [id])
  createdBy User            @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  deal      Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  items     QuotationItem[]

  @@index([companyId])
  @@index([status])
  @@index([issueDate])
  @@index([createdById])
  @@index([dealId])
  @@map("quotations")
}

// ============================================================
// 8. QUOTATION ITEM (Line items — polymorphic Product or Service)
// ============================================================
// Day 7: a line item is either a Product or a Service. Whichever it is, the
// name/description/unitPrice are snapshotted at quotation time so the
// historical quote doesn't drift when the catalogue changes.

enum ItemType {
  PRODUCT
  SERVICE
}

model QuotationItem {
  id          String   @id @default(cuid())
  quotationId String
  // Polymorphic: exactly one of productId or serviceId is set
  itemType    ItemType
  productId   String?
  serviceId   String?
  // Snapshot fields (immutable after creation)
  sku         String?  // for products; null for services
  name        String
  description String?  @db.Text
  // SOW/breakdown snapshot for service items: { lines: [{role, dayRate, days, subtotal}], notes }
  // For product items this stays null.
  manDaySnapshot Json?
  // Pricing
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)   // service.unitPrice or product.unitPrice at snapshot
  discount    Decimal  @default(0) @db.Decimal(5, 2) // percentage
  lineTotal   Decimal  @db.Decimal(12, 2)   // = quantity * unitPrice * (1 - discount/100)
  position    Int      @default(0)

  // Relations
  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  service   Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([quotationId])
  @@index([productId])
  @@index([serviceId])
  @@index([itemType])
  @@map("quotation_items")
}

// ============================================================
// 9. PIPELINE (Sales pipeline configuration)
// ============================================================

model Pipeline {
  id        String   @id @default(cuid())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stages PipelineStage[]
  deals  Deal[]

  @@map("pipelines")
}

model PipelineStage {
  id          String  @id @default(cuid())
  pipelineId  String
  name        String  // e.g., "Lead", "Qualified", "Proposal", "Negotiation", "Won", "Lost"
  position    Int     // Display order
  probability Int     @default(0) // 0-100, win probability %
  color       String?

  // Relations
  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, position])
  @@index([pipelineId])
  @@map("pipeline_stages")
}

// ============================================================
// 10. DEAL (Sales opportunity)
// ============================================================

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id          String     @id @default(cuid())
  title       String
  companyId   String
  ownerId     String     // Sales rep owning the deal
  pipelineId  String
  stageId     String
  // Status
  status      DealStatus @default(OPEN)
  // Financial
  value       Decimal    @db.Decimal(12, 2)
  currency    String     @default("HKD")
  // Dates
  expectedCloseDate DateTime?
  closedAt    DateTime?
  // Content
  description String?    @db.Text
  // Lost reason
  lostReason  String?
  // AI metadata
  aiInsights  Json?      // Cached AI analysis (next best action, risk score, etc.)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  company    Company        @relation(fields: [companyId], references: [id])
  owner      User           @relation("DealOwner", fields: [ownerId], references: [id])
  pipeline   Pipeline       @relation(fields: [pipelineId], references: [id])
  stage      PipelineStage  @relation(fields: [stageId], references: [id])
  quotations Quotation[]   // Day 8: a deal can have multiple quotations (revisions)
  activities ActivityLog[]

  @@index([companyId])
  @@index([ownerId])
  @@index([stageId])
  @@index([status])
  @@index([expectedCloseDate])
  @@map("deals")
}

// ============================================================
// 11. ACTIVITY LOG (All customer/deal interactions)
// ============================================================

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
  QUOTATION_SENT
  QUOTATION_VIEWED
  DEAL_STAGE_CHANGED
  SYSTEM
}

model ActivityLog {
  id          String       @id @default(cuid())
  type        ActivityType
  // Polymorphic: can relate to company, contact, or deal
  companyId   String?
  contactId   String?
  dealId      String?
  assignedToId String?     // Sales rep assigned
  // Content
  subject     String?
  body        String?      @db.Text
  // Metadata
  metadata    Json?        // e.g., {duration: 1800, outcome: "interested"}
  // Timing
  dueAt       DateTime?    // For tasks
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  // Relations
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal       Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("ActivityAssignedTo", fields: [assignedToId], references: [id])

  @@index([companyId])
  @@index([contactId])
  @@index([dealId])
  @@index([type])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================================
// 12. CONVERSATION (AI Agent memory)
// ============================================================

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String?   // Auto-generated from first message
  // Context (what data the agent had access to during this conversation)
  context   Json?     // Snapshot of relevant CRM data (companies, deals, etc.)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("conversations")
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant" | "tool"
  content        String   @db.Text
  // For tool calls
  toolName       String?
  toolArgs       Json?
  toolResult     Json?
  // Token tracking (for cost monitoring)
  promptTokens   Int?
  completionTokens Int?
  createdAt      DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

// ============================================================
// 13. AUDIT LOG (Admin-visible system event trail)
// ============================================================

enum AuditAction {
  // Auth
  USER_LOGIN
  USER_LOGIN_FAILED
  USER_LOGOUT
  PASSWORD_CHANGED
  // User management
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  USER_REACTIVATED
  USER_DELETED
  PASSWORD_RESET
  // Role management (Day 7)
  ROLE_CREATED
  ROLE_UPDATED
  ROLE_DELETED
  // CRM resources
  QUOTATION_CREATED
  QUOTATION_UPDATED
  QUOTATION_DELETED
  QUOTATION_STATUS_CHANGED
  COMPANY_CREATED
  COMPANY_UPDATED
  COMPANY_DELETED
  CONTACT_CREATED
  CONTACT_UPDATED
  CONTACT_DELETED
  DEAL_CREATED
  DEAL_UPDATED
  DEAL_DELETED
  // Service catalogue (Day 7)
  SERVICE_CREATED
  SERVICE_UPDATED
  SERVICE_DELETED
  // Product catalogue
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
}

model AuditLog {
  id          String      @id @default(cuid())
  // Actor
  actorId     String?     // null = anonymous / system
  // What happened
  action      AuditAction
  // Affected resource
  resourceType String?    // e.g., "quotation", "user", "company"
  resourceId   String?
  // Free-form context
  description  String?    @db.Text
  metadata     Json?      // before/after diff, etc.
  // Request context
  ipAddress    String?
  userAgent    String?    @db.Text
  createdAt    DateTime   @default(now())

  // Relations
  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
