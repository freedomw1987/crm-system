{
  "name": "@crm/api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist --minify",
    "start": "bun --env-file=../../.env dist/index.js",
    "typecheck": "tsc --noEmit --skipLibCheck --noResolve",
    "lint": "echo 'lint: not configured yet'",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@crm/ai": "workspace:*",
    "@crm/db": "workspace:*",
    "@crm/shared": "workspace:*",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/jwt": "^1.2.0",
    "elysia": "^1.4.28",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "xlsx-js-style": "^1.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/lodash": "^4.17.23"
  }
}
