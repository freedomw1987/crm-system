# ==========================================
# crm-system environment variables
# Copy to .env and fill in real values
# ==========================================

# ----- General -----
NODE_ENV=development
LOG_LEVEL=info

# ----- Database (Postgres) -----
# Local dev: docker-compose up postgres
# Production: RDS Postgres (ap-east-1)
DATABASE_URL=postgresql://crm:crm_dev_password@localhost:5432/crm_system?schema=public

# ----- API -----
API_PORT=3001
API_HOST=0.0.0.0
# Comma-separated list. Includes the docker compose web port (80)
# and the vite dev port (5173) so the same .env works for both
# `docker compose up` and `bun run dev:web`.
CORS_ORIGIN=http://localhost,http://localhost:5173

# ----- Auth -----
# 64 hex chars (32 bytes) for AES-256-GCM. Generate with:
#   openssl rand -hex 32
# This is REQUIRED — the API container will refuse to start otherwise
# (the compose file uses ${VAR:?} expansion). AI features (admin
# saving an OpenAI key) fail at runtime if missing/invalid.
AI_CONFIG_ENCRYPTION_KEY=__GENERATE_WITH_openssl_rand_hex_32__
JWT_SECRET=__GENERATE_WITH_openssl_rand_hex_32__
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ----- AI Agent (OpenAI) -----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3

# ----- Frontend -----
VITE_API_URL=http://localhost:3001
