# ==========================================
# crm-system environment variables
# Copy to .env and fill in real values
# ==========================================

# ----- General -----
NODE_ENV=development
LOG_LEVEL=info

# ----- Database (Postgres) -----
# Local dev: docker-compose up postgres
# Production: RDS Postgres (ap-east-1)
DATABASE_URL=postgresql://crm:crm_dev_password@localhost:5432/crm_system?schema=public

# ----- API -----
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# ----- Auth -----
JWT_SECRET=change-me-to-a-random-32-char-string-in-prod
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ----- AI Agent (OpenAI) -----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3

# ----- Frontend -----
VITE_API_URL=http://localhost:3001
